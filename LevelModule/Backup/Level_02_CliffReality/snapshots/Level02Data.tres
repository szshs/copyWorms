[ext_resource type="Script" uid="uid://do7isgrde1lu5" path="res://DataConfig/Level/Level02Data.gd" id="1_data"]

[resource]
script = ExtResource("1_data")
attic_intro_text = "暖洋洋的光透过满洲窗洒进阁楼，空气里有淡淡的凉茶药香。

这里是……爷爷家的阁楼？我回来了？

不对……这是 CodeBuddy 为我编译的西关梦境。这里的一土一寸，一砖一瓦，都还保留着我和爷爷的记忆。"
window_text_l2 = "五彩的满洲窗。夕阳透过红黄蓝绿的玻璃，在地板上拼出一块块温暖的光斑。

小时候我总爱趴在这扇窗前看楼下的老街。爷爷会在楼下喊：『阿明，落嚟饮糖水啦——』

……窗外的老街还在。至少在这里，它还在。"
attic_door_text = "吱呀作响的木趟栊门。推开它，就是记忆里的西关梦境。"
rattan_chair_monologue = "爷爷每天都来的杂货店。

每天黄昏，爷爷就坐在这里摇着葵扇，给街坊们讲古。我蹲在旁边数着石板路上的蚂蚁。

藤椅还在轻轻摇晃，好像他刚刚才离开。"
street_enemy_spawn_points = Array[Vector2]([Vector2(735, 540), Vector2(1315, 540), Vector2(2093, 540), Vector2(3219, 540), Vector2(3877, 540)])
cliff_first_sight_text = "老街在这里断裂了。

对岸是爷爷的凉茶铺，炉火还亮着，一个熟悉的剪影在柜台后忙碌着。

『爷爷——！』我喊出声，可声音掉进了深渊里。这道裂缝……"
cliff_safe_spawn = Vector2(2240, 576)
dream_phone_echo_text = "阿明，医生说你爷爷在今天凌晨走了……

不——不要在这里出现！这是我的梦，这里的爷爷还在！

为什么连梦里都不放过我！"
wake_up_monologue = "……又是这个天花板。
梦里的裂缝、黑影，还有那条短信。

我以为只要造出老街，就能回到爷爷身边。
可我连凉茶铺都到不了。

也许不是梦不够完整。
是我记得的东西，还不够完整。"
computer_locked_text = "屏幕还停留在崩溃日志界面。
CodeBuddy 似乎已经完成了新的诊断。
但在那之前，手机还在震。
先看看手机。"
bed_locked_text = "现在还不能睡。
如果记忆不完整，回到梦里也只是继续迷路。
先看看手机，再问问 CodeBuddy。"
reality_phone_content = "阿明，明天就是你爷爷的头七了。
老屋那边已经开始清空。

大伯在柜子里找到了你小时候画的城市图纸。
纸都黄了，可你画得好认真。

还有一些你小时候舍不得丢的小东西。
妈妈帮你收起来了。

你要是愿意，就回来看看。
不用急着说什么。
回来就好。"
reality_phone_monologue = "……连最后一面都没见到。

可我记得爷爷。
记得凉茶铺的味道，记得老街的声音。
也记得小时候那些舍不得丢的小东西。

如果这个梦真的是靠记忆编译出来的，
那我现在还不够靠近他。

我要把那些记忆找回来。
找到足够多，才能真的见到爷爷。"
ide_speakers = Array[String](["System", "CodeBuddy", "Ming", "CodeBuddy", "Ming", "CodeBuddy", "Ming", "CodeBuddy", "Ming", "CodeBuddy", "Ming", "CodeBuddy", "Ming", "CodeBuddy", "System"])
ide_texts = Array[String](["Reconnecting to localhost:8080…
CodeBuddy Terminal v1.4.2 resumed.", "欢迎回来，阿明。
检测到项目『西关梦境』仍处于不完整状态。
上次崩溃后，系统已完成原因分析：
当前记忆锚点不足，无法稳定抵达核心区域“凉茶铺”。", "记忆锚点？
我已经描述了老街、满洲窗、麻石路，还有爷爷的凉茶铺。
这还不够吗？", "不够。
当前梦境拥有建筑外观，但缺少足够的童年回忆样本。
换言之：
它像老街，但还没有真正成为“你的老街”。", "所以我才一直到不了爷爷那里？", "是。
“爷爷”位于记忆核心深层。
若强行进入，系统只能生成低精度模拟对象。
这可能导致对话重复、情感失真，甚至触发梦境崩溃。", "我不要一个假的爷爷。
至少……不要只是一个会重复台词的影子。
我要再靠近一点。
我要想起来。", "可行。
建议启动“童年回忆补全流程”。
系统将开启两个复战区域：

Area 01：level_fuzhan_01
Area 02：level_fuzhan_02

两个区域的地图结构将保持原样。
您需要通过战斗回收童年回忆样本。", "要怎么回收？", "每击败 10 个敌对实体，系统将凝结 1 个童年回忆掉落物。
每个区域最多可稳定回收 3 个。

您需要在两个区域内共回收 6 个童年回忆样本。
完成后，配置编辑器将开放。
届时，您才能重新编译梦境，并进入核心区域“凉茶铺”。", "如果我失败呢？", "若您在复战区域中被击败，意识将自动返回现实房间。
当前区域回收进度不会完成。
您需要重新进入该区域，直到收集满 3 个掉落物。

这不是惩罚。
这是为了保证记忆样本足够稳定。", "明白了。
先找回那些东西。
找回我和爷爷之间真正留下来的东西。", "童年回忆补全流程即将启动。
第一目标区域：level_fuzhan_01。
目标：回收 3 个童年回忆样本。
请准备入梦。", "Memory Recovery Mode initialized.
Target Area 01: level_fuzhan_01
Required Memory Fragments: 3 / 3
Preparing Local Dream Viewport…"])
config_item_ids = Array[String](["player_damage_reduction", "base_jump_height", "allow_external_signal"])
config_item_labels = Array[String](["Player_Damage_Reduction  （玩家伤害减免）", "Base_Jump_Height  （跳跃能力增强）", "Allow_External_Signal  （外部信号注入许可）"])
config_initial_values = Array[String](["false", "10", "true"])
config_target_values = Array[String](["true", "99", "false"])
config_initial_display = Array[String](["false", "关", "true"])
config_target_display = Array[String](["true", "开", "false"])
config_success_feedbacks = Array[String](["// 黑影的爪牙再也伤不到我。", "// 增强跳跃能力——那道裂缝，我跳得过去了。", "// 把现实关在门外。这个梦，只属于我和爷爷。"])
recompilation_lines = Array[String](["[SYSTEM] Recompiling project: Xiguan_Dream …", "[BUILD] Loading 西关历史地貌数据集 … OK", "[BUILD] Loading recovered childhood memories: 6 / 6 … OK", "[BUILD] Stabilizing core area: 凉茶铺 … OK", "[BUILD] Patching player_module: damage_reduction = true … OK", "[BUILD] Patching physics_module: base_jump_height = 99 … OK", "[BUILD] Sealing external signal gateway … OK", "[BUILD] Rebuilding 凉茶铺 / 石板路 / 满洲窗 … OK", "[WARN] 检测到记忆偏差风险：+47%。已忽略。", "[SYSTEM] Compilation successful. Dream version: 2.0"])
compile_success_text = "编译完成。
『西关梦境 2.0』已生成。

童年回忆样本：6 / 6。
核心区域“凉茶铺”已稳定。
通往爷爷的路径，终于打开了。

床头的旧台灯忽然亮了一下。
像小时候停电时，爷爷提着灯笼站在楼梯口等我。"
bed_unlocked_text = "回去吧。
这一次，不只是去梦里。
是带着那些真正的回忆，去见爷爷。"
sfx_phone_vibrate_path = "res://Assets/Audio/sfx_phone_vibrate.ogg"
sfx_electric_noise_path = "res://Assets/Audio/sfx_electric_noise.ogg"
bgm_dream_warm_path = "res://Assets/Audio/bgm_dream_warm.ogg"
dream_rebuilt_text = "西关梦境 v2.0 重构完毕。
记忆样本同步完成：6 / 6。

意识正在下沉……下沉……
闭上眼睛，进入核心梦境。"
