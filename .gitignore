# ============================================
# .gitignore — 本地保留 Godot 源码，远程只推送 web 导出 + 部署配置
# ============================================

# --- Godot 源码目录（本地保留，不推送到远程） ---
Assets/
DataConfig/
EnemyModule/
Global/
LevelModule/
PlayerModule/
Resources/
Scenes/
Scripts/
Tools/
UI/

# --- Godot 项目文件 ---
project.godot
project.godot.txt
export_presets.cfg

# --- 自动生成 ---
*.import
*.uid
.godot/

# --- 根目录重复的 web 导出文件（正式的在 build/web/） ---
/index.html
/index.js
/index.wasm
/index.pck
/index.side.wasm
/index.audio.worklet.js
/index.audio.position.worklet.js
/index.icon.png
/index.apple-touch-icon.png
/index.png

# --- 构建产物（只保留 build/web/） ---
/build/export.log
/build/tmpl_install.log

# --- 其他不需要的文件 ---
push.log
generated/
addons/
AI资源库/
godot-editor/

# --- IDE / 系统 ---
.idea/
.vscode/
.codebuddy/
.godot-mcp/
.DS_Store
__MACOSX/
.env
.edgeone/*
.tef_dist/*
  