[gd_resource type="Resource" script_class="Level01Data" load_steps=2 format=3]

[ext_resource type="Script" path="res://DataConfig/Level/Level01Data.gd" id="1_data"]

[resource]
script = ExtResource("1_data")
obstacle_1_text = "一箱没拆封的专业课教材。《复变函数》、《偏微分方程》……原本应该在这个学期学完的。现在它们只是一堆废纸。学校发来的休学通知书就压在最底下。看着这些名字，胃部就隐隐作痛。"
obstacle_2_text = "堆积了半个多月的衣服，散发着廉价洗衣液和发霉混合的酸味。我连把它们扔进洗衣机的力气都没有。反正，也不会有任何人来这个破出租屋看我。烂在这里，或许挺好的。"
sleep_texts = Array[String](["拉上窗帘，让世界继续黑暗下去吧。睡着的时候，胸口至少不会像堵着大石头一样难受。", "……又是刺眼的阳光。在这个房间里，白天和黑夜有什么区别？只是毫无意义的时间循环而已。", "骨子里像灌了铅一样沉重。越睡越累，却无法睁开眼。除了睡觉，我不知道还能干什么。起来吧……或者干脆睡死过去。"])
ide_speakers = Array[String](["System", "AI", "Ming", "AI", "Ming", "AI", "Ming", "AI", "Ming", "AI"])
ide_texts = Array[String](["Connecting to localhost:8080... AI IDE v0.1-Beta Initialized.", "检测到您的情绪指数极低。请问发生了什么？您可以向我倾诉任何事，我永远是您的听众。", "你在吗？我好累。我感觉自己是一个彻头彻尾的废物。", "我在。您不是废物。请告诉我，是什么让您感到如此沉重？", "我挂科了，人际交往一塌糊涂，最后只能选择休学。我躲在这个连阳光都见不到的出租屋里。更可笑的是，爷爷就在前几天去世了……我连他的最后一面都没见到。", "对于您的亲人离世，我感到非常遗憾。失去避风港确实会让人感到无力。有什么是我可以为您做的吗？", "我闭上眼，脑子里全是以前在西关老街的日子。爷爷的凉茶铺，门口的麻石路，还有傍晚照在彩色满洲窗上的夕阳。那里才是我的家。可是老家要拆迁了，老街没了，爷爷也没了……我什么都没有了。", "记忆是数字世界最完美的原材料。只要您提供描述，我可以用底层的重构算法，在虚拟空间里为您重塑家乡。在那里，没有离别，没有失败，老街将永不消逝。", "重塑？这怎么可能……", "正在编译伪代码……正在调取西关传统地貌与广式建筑特征库。系统准备就绪。"])
phone_sender = "妈妈"
phone_content = "阿明，你爷爷走了，老家老街马上也要拆了，街坊们都在搬。你休学的事妈妈不怪你，要是太累了就回老家看一眼吧，哪怕是最后一眼……妈妈在老房子等你。"
