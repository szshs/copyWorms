[gd_resource type="Resource" script_class="Level01Data" load_steps=2 format=3]

[ext_resource type="Script" path="res://DataConfig/Level/Level01Data.gd" id="1_data"]

[resource]
script = ExtResource("1_data")
obstacle_1_text = "我亲手把这些箱子堆在这里的。

箱子里是没拆封的《复变函数》和《电磁场理论》。休学申请通过的那天，我把它们从书架上扫下来，严严实实地堵住了门。

我不想出去，也不想让任何人进来。这个房间就是我的世界，挺好的。"
obstacle_2_text = "散发着廉价洗衣液和发霉方便面混合的酸臭味。

已经半个月没去清理了。地上的污渍像是一块块霉斑，慢慢啃食着这个房间。我也一样，正在被一些看不见的东西慢慢啃食。

算了，没力气动，就这样吧。"
notice_text = "『鉴于该生心理评估结果及个人申请，予以休学一年……』

辅导员签字时的眼神很温和，温和得像是在看一个无可救药的累赘。同龄人现在应该都在准备期末考或者保研吧。而我，连站上跑道的资格都被自己剥夺了。"
thermos_text = "手写的字条上歪歪扭扭地写着：『阿明，广州湿冷，记得多喝热水。』

这是爷爷在我上大学第一年寄过来的。杯底早已干涸，但凑近了，似乎还能闻到淡淡的二十四味凉茶药香。

那个时候，爷爷的身体还很硬朗，凉茶铺的炉火总是温热的。可现在……我有多久没给他打过电话了？"
sleep_texts = Array[String](["拉上窗帘。让世界继续黑暗下去吧。", "……又是刺眼的阳光。在这个房间里，白天和黑夜有什么区别？", "骨子里像灌了铅一样沉重。除了逃避，我不知道还能干什么。起来吧，或者干脆睡死过去。"])
ide_speakers = Array[String](["System", "CodeBuddy", "Ming", "CodeBuddy", "Ming", "CodeBuddy", "Ming", "CodeBuddy", "System"])
ide_texts = Array[String](["Connecting to localhost:8080... CodeBuddy Terminal v1.4.2 initialized.", "您好，阿明。检测到系统已有 364 小时未接收到您的有效编译请求。当前情绪参数评估：极度低迷。需要启动日常辅助对话吗？", "我写不出代码，也做不完课题。我是一个彻头彻尾的废物，CodeBuddy。", "无法从逻辑上支持您的自我定义。学业暂时中断属于客观事件，不构成个人性质判定的充分条件。请问是否有具体的压力源需要排除？", "我没办法排除……爷爷病危，老家要拆，而我却像个懦夫一样躲在这里。我闭上眼，脑子里全是西关老街的样子。爷爷的凉茶铺、石板路、还有傍晚照在满洲窗上的夕阳。那里才是我的家。可是老街要拆了，我什么都没有了。", "明白。现实物理实体的消亡是不可逆的熵增过程。但基于您的记忆描述，结合广式西关建筑的公开数据集，我可以为您建立一个数字化的静态备份。只要您提供描述参数，我将为您编译重构项目：『Xiguan_Dream』。是否开始输入参数？", "……开始吧。", "正在调取西关历史地貌与传统建筑特征库。正在编译代码……[System] 正在初始化项目，本地测试预览即将启动。", "Compilation successful. Initializing Local Preview Viewport..."])
phone_sender = "妈妈"
phone_content = "阿明，医生说你爷爷在今天凌晨走了。他走得很安详，一直念叨着让你别太累。还有，旧城区拆迁工程下周正式动工，老街坊们都在打包行李了……你要是累了，就回老家看一眼吧。哪怕是最后一眼。"
climax_monologue = "爷爷……走了。

老街，也要被推平了。

原来，我在这个世界上，真的已经一无所有了。"
