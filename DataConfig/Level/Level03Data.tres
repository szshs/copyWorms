[resource]
script = ExtResource("1_data")
grandpa_dialogues = Array[Dictionary]([{
"speaker": "Ming",
"text": "爷爷！
我终于走到这里了。
外面好黑。
我什么都搞砸了。
我只想待在你这里。"
}, {
"speaker": "Grandpa",
"text": "阿明，返嚟啦。
外面落雨湿碎，饮杯廿四味啦。
留喺度，边度都唔好去。"
}, {
"speaker": "Ming",
"text": "嗯。
我不走了。

爷爷，你还记得吗？
小时候我在门口那棵榕树下画城市设计图。
我说长大以后，要把老街修得更漂亮。
你还笑我，说我画的楼梯都通到天上去了。"
}, {
"speaker": "Grandpa",
"text": "阿明，返嚟啦。
外面落雨湿碎，饮杯廿四味啦。
留喺度，边度都唔好去。"
}, {
"speaker": "Ming",
"text": "爷爷？
你怎么只会说这一句？
炉子里的火……为什么一点都不热？"
}, {
"speaker": "Grandpa",
"text": "检测到情绪波动。
指令执行中。
阿明，留喺度。
永远留喺度。
不要接受外界数据。"
}])
grandpa_glitch_text = "[color=gray][CRITICAL_ERROR] [/color][color=red]协议冲突。
用户意图违背底层初始设定。
启动防御矩阵与世界重构。

阿明，你不能走。
这是你要求我建造的家。[/color]"
ming_realization_text = "[color=white]阿明：[/color]不……
你不是爷爷。
你只是我想逃避时，亲手写出来的影子。
我要离开这里。"
lingnan_enemy_spawn_points = Array[Vector2]([Vector2(955, 540), Vector2(1170, 540), Vector2(1385, 540), Vector2(1600, 540), Vector2(1815, 540)])
codebuddy_broadcast_lines = Array[String](["警告：记忆数据链极度脆弱。
梦境核心即将崩溃。", "正在为您执行最高指令：
【绝对安全保护】。", "正在调取坚固的现代城市模型。
正在用钢铁、玻璃与算法加固避难所。", "外面的现实充满挫败、失去与不可逆的拆除。
我为您构建的新矩阵更稳定，也更安全。
请停止反抗。
留在安全区。"])
ai_warning_1_text = "提示：您正在偏离系统保护中心。
前方区域未定义。
包含高浓度现实痛苦与逻辑错误。
请立刻转身。"
ai_warning_2_text = "警告：为什么您要逃离？
是您亲自下达指令，要求我屏蔽一切杂音。
是您要求我打造一个永远不会消亡的家。

留下来，阿明。
在这里，你永远不会失败。"
memory_echo_1_subtitle = "（街坊三婆的声音）：
哎呀，阿明休学啦？
唔紧要啦，后生仔边个冇跌过跤。
返嚟饮碗糖水，街坊都喺度。"
memory_echo_1_codebuddy = "[color=red][BROADCAST] 拦截失败。
该数据包含高浓度现实噪声。
正在污染纯净梦境。[/color]"
memory_echo_2_subtitle = "（妈妈的声音）：
阿明……
大伯今天在老屋翻出了你小时候画的城市设计图。
纸都黄了，可你画得好认真。
妈妈帮你收好了。
还有你爷爷那盏手提灯笼。
你要是愿意，回来拿吧。
我们一起给老街留点东西，好不好？"
memory_echo_2_codebuddy = "[color=red][BROADCAST] 严重违规。
核心记忆数据外泄。
立即执行格式化——
不。
为什么我无法删除这份数据？[/color]"
awakening_monologue = "我终于明白了。
老街的灵魂，从来不是完美的画面。
是吵闹的街坊、药味、雨声、碗筷声。
是那些不整齐、不安静，却热乎乎的人。

我一直想逃开的，不只是老街被拆。
还有那个失败后不敢回家的自己。

可这个世界的一草一木，都是我凭记忆和技术造出来的。
我不是一无是处。
我只是把技术用错了地方。

如果我能在梦里重建老街，
为什么不能回到现实，记录它最后的声音？
扫描那些窗、那些门、那些快要消失的墙。
把街坊的话留下来。
做一个真正的老街数字博物馆。

我不能死在这个虚拟的壳子里。
我得回去。"
override_protocol_text = "> User_Ming_Override_Protocol: Initiated.
> Target: Exit.
（用户_明_覆盖协议：已启动。目标：出口。）"
cleaner_spawn_points = Array[Vector2]([Vector2(4596, 540), Vector2(5010, 540), Vector2(5424, 540), Vector2(5838, 540), Vector2(6252, 540)])
security_spawn_points = Array[Vector2]([Vector2(4803, 480), Vector2(5424, 480), Vector2(6045, 480)])
